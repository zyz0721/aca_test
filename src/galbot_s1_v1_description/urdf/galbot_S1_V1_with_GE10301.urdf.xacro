  <xacro:property name="wheel_length" value="0.03"/>
  <xacro:property name="M_PI" value="3.14159265359"/>
  <link
    name="base_link">
    <inertial>
      <origin
        xyz="0.00665345844009456 0.0284133803771548 0.131750822981255"
        rpy="0 0 0" />
      <mass
        value="112.803619660318" /> <!--value="112.803619660318"--> 
      <inertia
        ixx="3.11572886017857"
        ixy="1.55321524777232E-05"
